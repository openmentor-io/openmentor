# ============================================================================
# Production Deployment & Runtime Configuration
# ============================================================================
# COPY THIS FILE TO: .env.production
# This file contains ALL production configuration:
#   - Deployment machine settings (SSH, registry credentials)
#   - Build-time variables (NEXT_PUBLIC_*)
#   - Runtime application secrets
# NEVER commit .env.production to version control!
# ============================================================================

# ============================================================================
# DEPLOYMENT MACHINE CONFIGURATION
# ============================================================================
# These variables are used by the deployment script on your local machine

# Container registry credentials
# TODO(P6.4): move to AWS ECR (D19) (GitHub Container Registry) — Yandex registry
# kept temporarily; the registry swap is ops work tracked as P6.4.
# Path to the Yandex service account JSON key file on your LOCAL machine
YANDEX_SA_KEY_FILE=/path/to/yandex-service-account-key.json

# Production VM SSH Configuration (default hosting: Hetzner Cloud VM, EU — DECISIONS D2)
VM_SSH_HOST=your.production.vm.ip
VM_SSH_USER=your_ssh_username
# Optional: path to an SSH PRIVATE key file for VM access. Leave unset/empty
# to use your SSH agent instead (recommended with the 1Password SSH agent).
#VM_SSH_KEY_FILE=/path/to/ssh-private-key

# ============================================================================
# BUILD-TIME ENVIRONMENT VARIABLES (for frontend)
# ============================================================================
# These are baked into the frontend image at build time

NEXT_PUBLIC_GO_API_URL=http://backend:8081
# Image host for next/image — path-style S3 endpoint host + bucket, matching
# the S3_STORAGE_* config below (AWS S3, DECISIONS D15)
NEXT_PUBLIC_S3_STORAGE_ENDPOINT=s3.eu-central-1.amazonaws.com
NEXT_PUBLIC_S3_STORAGE_BUCKET=mentor-images
NEXT_PUBLIC_CDN_ENDPOINT=cdn.openmentor.io
NEXT_PUBLIC_O11Y_SERVICE_NAMESPACE=openmentor-frontend
NEXT_PUBLIC_O11Y_FE_SERVICE_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_ANALYTICS_PROVIDER=posthog
NEXT_PUBLIC_ANALYTICS_EVENT_VERSION=v1
# PostHog project key/host for the frontend (client + server-side capture);
# the frontend skips analytics init when the key is empty
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Optional: PostHog sourcemap upload at build time (next.config.js)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Optional: Grafana Faro RUM (frontend skips init when the collector URL is
# empty). FARO_* are used for sourcemap upload during the image build.
NEXT_PUBLIC_FARO_COLLECTOR_URL=
NEXT_PUBLIC_FARO_APP_NAME=openmentor-frontend
NEXT_PUBLIC_FARO_SAMPLE_RATE=0.5
FARO_API_ENDPOINT=
FARO_APP_ID=
FARO_STACK_ID=
FARO_API_KEY=

# ============================================================================
# INFRASTRUCTURE CONFIGURATION
# ============================================================================

# Domain Configuration
DOMAIN=openmentor.io
LETSENCRYPT_EMAIL=admin@openmentor.io

# Cloudflare DNS API Token (for DNS-01 ACME challenge)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Use "Edit zone DNS" template, scoped to your domain
CLOUDFLARE_DNS_API_TOKEN=your_cloudflare_dns_api_token

# Environment
APP_ENV=production
LOG_LEVEL=info

# Yandex Container Registry ID
# TODO(P6.4): move to AWS ECR (D19) — see registry note above
YANDEX_REGISTRY_ID=crpXXXXXXXXXXXX

# Image tag (auto-populated by deployment script - DO NOT SET MANUALLY)
IMAGE_TAG=

# ============================================================================
# BACKEND RUNTIME CONFIGURATION
# ============================================================================

# Server
PORT=8081
GIN_MODE=release
LOG_DIR=/app/logs

# PostgreSQL (DECISIONS D2): the production DB is the `postgres` container in
# docker-compose.yml, backed by the external `openmentor-postgres-data`
# volume (created by deploy.sh; `docker compose down -v` cannot delete it).
# POSTGRES_* provision the container; DATABASE_URL (used by migrate, backend
# and worker) must match them. There is no compose-level default for
# POSTGRES_PASSWORD - the container refuses to start without one.
POSTGRES_USER=openmentor
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=openmentor

# sslmode=disable is correct here: the container is reachable only on the
# internal Docker network, so no TLS is needed. Managed-PG scale path
# (Neon/RDS, D2): swap ONLY this URL to the managed host with
# sslmode=verify-full and pass the provider CA via sslrootcert=<path> in the
# DSN (standard pgx/libpq behavior; or rely on the system trust store).
DATABASE_URL=postgres://openmentor:your_strong_password@postgres:5432/openmentor?sslmode=disable

# ----------------------------------------------------------------------------
# Postgres backups (postgres-backup sidecar)
# ----------------------------------------------------------------------------
# Nightly pg_dump (custom format) of ${POSTGRES_DB} at BACKUP_TIME (UTC),
# uploaded to s3://$BACKUP_S3_BUCKET/$BACKUP_S3_PREFIX/ and pruned there
# after BACKUP_RETENTION_DAYS. SET THE BUCKET IN PRODUCTION: with it empty,
# dumps stay only in a local volume and die with the VM (the sidecar logs a
# loud warning). Restore runbook: ../docs/runbooks/postgres-backup-restore.md
BACKUP_S3_BUCKET=openmentor-db-backups
BACKUP_S3_PREFIX=postgres
BACKUP_TIME=03:30
BACKUP_RETENTION_DAYS=30
# S3 credentials: BACKUP_AWS_* take precedence; when empty the sidecar falls
# back to S3_STORAGE_ACCESS_KEY/S3_STORAGE_SECRET_KEY (+ S3_STORAGE_REGION)
# below. Prefer a dedicated IAM user scoped to the backup bucket.
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_REGION=eu-central-1

# S3 Object Storage (profile pictures, used by the Go backend)
# Decided: AWS S3 (DECISIONS D15). Example (AWS S3, eu-central-1):
#   S3_STORAGE_ENDPOINT=https://s3.eu-central-1.amazonaws.com, S3_STORAGE_REGION=eu-central-1
# Any other S3-compatible provider still works by swapping endpoint/region:
#   Cloudflare R2: S3_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com, S3_STORAGE_REGION=auto
S3_STORAGE_ACCESS_KEY=your_access_key
S3_STORAGE_SECRET_KEY=your_secret_key
S3_STORAGE_BUCKET=mentor-images
S3_STORAGE_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_STORAGE_REGION=eu-central-1

# ============================================================================
# TRANSACTIONAL EMAIL - AWS SES (DECISIONS D1)
# ============================================================================
# Consumed by the background worker container (email sender uses the SESv2
# API). The worker runs from the backend image (/app/worker) and reads this
# same .env file.

SES_REGION=eu-central-1
SES_ACCESS_KEY_ID=your_ses_access_key_id
SES_SECRET_ACCESS_KEY=your_ses_secret_access_key
# Optional: custom SESv2-compatible endpoint (leave empty for AWS SES)
SES_ENDPOINT=

# Moderator notifications recipient (new mentor / new request emails)
MODERATORS_EMAIL=moderators@openmentor.io

# Non-production email reroute: when set (and APP_ENV != production), ALL
# outgoing emails are rerouted to this address instead of real recipients.
# MUST be empty in production.
DEV_EMAIL_OVERRIDE=

# ============================================================================
# BACKGROUND WORKER (worker container, /app/worker from the backend image)
# ============================================================================
# The worker serves the API's async event triggers on the internal network
# and runs the daily cron jobs. It replaces the deprecated openmentor-func
# Azure Functions app.

# Shared secret for the X-Worker-Token header: the worker requires it on all
# /jobs/* requests when set, and the API sends it on every trigger call.
# Generate with: openssl rand -hex 32
WORKER_AUTH_TOKEN=your_worker_auth_token

# Master switch for the worker's scheduled (cron) jobs
WORKER_CRON_ENABLED=true

# Optional: comma-separated mentor ids the randomize-sort-order cron job
# pins to the top of the catalog (leave empty for none)
HIGHLIGHTED_MENTORS=

# Event trigger URLs the API calls after database writes (fire-and-forget).
# They point at the worker container's internal HTTP server. For the
# CallAsync-style URLs the record id is appended verbatim, so keep the
# trailing "?param=". The JSON POST triggers (mentor-login-email,
# moderator-login-email, mentor-moderation-action) take the bare endpoint
# URL with NO query string.
MENTOR_CREATED_TRIGGER_URL=http://worker:8090/jobs/new-mentor-watcher?mentorId=
MENTOR_REQUEST_CREATED_TRIGGER_URL=http://worker:8090/jobs/new-request-watcher?requestId=
MENTOR_LOGIN_EMAIL_TRIGGER_URL=http://worker:8090/jobs/mentor-login-email
MODERATOR_LOGIN_EMAIL_TRIGGER_URL=http://worker:8090/jobs/moderator-login-email
MENTOR_MODERATION_TRIGGER_URL=http://worker:8090/jobs/mentor-moderation-action
REQUEST_PROCESS_FINISHED_TRIGGER_URL=http://worker:8090/jobs/request-process-finished?requestId=
REVIEW_CREATED_TRIGGER_URL=http://worker:8090/jobs/process-mentee-review?reviewId=
# MENTOR_UPDATED_TRIGGER_URL: leave unset - the worker has no endpoint for it
# (the legacy update-mentor-image thumbnail function was not ported).
MENTOR_UPDATED_TRIGGER_URL=

# ============================================================================
# AUTHENTICATION TOKENS (Generate with: openssl rand -base64 32)
# ============================================================================

# Public API Tokens
MENTORS_API_LIST_AUTH_TOKEN=your_token_here

# Internal API Tokens (CRITICAL - Frontend needs these to call Backend)
# Both variables are required - they should have the same value
INTERNAL_MENTORS_API=your_internal_token_here
GO_API_INTERNAL_TOKEN=your_internal_token_here

# JWT signing secret for mentor/admin passwordless-login sessions
# (backend refuses logins if unset)
JWT_SECRET=your_jwt_secret_here

# Webhook Secrets

# Next.js Integration

# ============================================================================
# CAPTCHA CONFIGURATION (Cloudflare Turnstile)
# ============================================================================

# Cloudflare Turnstile (form spam/bot protection)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# ============================================================================
# BACKEND / WORKER ANALYTICS - PostHog (server-side product events)
# ============================================================================
# The Go api and worker emit product analytics (source_system=api/worker).
# Set ANALYTICS_PROVIDER=none to disable server-side analytics entirely.
ANALYTICS_PROVIDER=posthog
ANALYTICS_EVENT_VERSION=v1
POSTHOG_API_KEY=your_posthog_project_api_key
POSTHOG_HOST=https://eu.i.posthog.com

# ============================================================================
# OBSERVABILITY - GRAFANA CLOUD
# ============================================================================

# Prometheus Metrics
GCLOUD_HOSTED_METRICS_URL=https://prometheus-xxx.grafana.net/api/prom/push
GCLOUD_HOSTED_METRICS_ID=your_metrics_username

# Loki Logs
GCLOUD_HOSTED_LOGS_URL=https://logs-xxx.grafana.net/loki/api/v1/push
GCLOUD_HOSTED_LOGS_ID=your_logs_username

# Tempo Traces (OTLP over HTTP)
# IMPORTANT: Endpoint must end with /otlp for OpenTelemetry HTTP protocol
# Example: https://tempo-prod-08-prod-eu-west-3.grafana.net/otlp
GCLOUD_HOSTED_TRACES_URL=https://tempo-xxx.grafana.net/otlp
GCLOUD_HOSTED_TRACES_ID=your_traces_username

# Pyroscope Profiles
GCLOUD_HOSTED_PROFILES_URL=https://profiles-xxx.grafana.net
GCLOUD_HOSTED_PROFILES_ID=your_profiles_username

# Grafana Cloud API Key
GCLOUD_RW_API_KEY=your_grafana_cloud_api_key

# Metrics Authentication Token
METRICS_AUTH_TOKEN=your_metrics_auth_token

# Prometheus scrape interval for all Alloy scrape jobs (optional, default 30s)
PROMETHEUS_SCRAPE_INTERVAL=30s

# Service Naming (used by Grafana Alloy for labeling)
O11Y_SERVICE_NAMESPACE=openmentor-io
O11Y_BE_SERVICE_NAME=openmentor-api
O11Y_FE_SERVICE_NAME=openmentor-frontend
# Worker observability identity: Alloy scrape/log labels, its trace
# service name AND its continuous-profiling app name (the worker ignores
# O11Y_PROFILING_APP_NAME so its profiles never mix with the API's)
O11Y_WORKER_SERVICE_NAME=openmentor-worker

# OTLP trace exporter endpoint for the Go binaries (api and worker both
# read it; Alloy's otelcol receiver, host:port without scheme).
# Leave empty to disable tracing.
O11Y_EXPORTER_ENDPOINT=alloy:4318

# Database Observability - PostgreSQL
# DSN for the dedicated monitoring user (not the app user). It points at the
# `postgres` compose container; sslmode=disable is correct on the internal
# network. deploy.sh writes this to
# /opt/openmentor-infra/alloy-secrets/postgres_secret_openmentor.
# If you move to a TLS-verified managed cluster, swap the host and set
# sslmode/sslrootcert in the DSN (mount the CA into the Alloy container
# yourself).
#
# Required PostgreSQL setup (one-time, `docker exec -it openmentor-postgres
# psql -U openmentor`):
#   CREATE USER grafana_monitoring WITH PASSWORD 'your_password';
#   GRANT pg_monitor TO grafana_monitoring;
#   GRANT CONNECT ON DATABASE openmentor TO grafana_monitoring;
#
# Also enable pg_stat_statements via shared_preload_libraries.
POSTGRES_OBS_DSN=postgres://grafana_monitoring:your_password@postgres:5432/openmentor?sslmode=disable

# Backend Continuous Profiling
# Production default: keep disabled until staging sign-off.
# Continuous profiling is shared by the api and worker containers;
# O11Y_PROFILING_APP_NAME names the API's profile stream only (the worker
# uses O11Y_WORKER_SERVICE_NAME)
O11Y_PROFILING_ENABLED=false
O11Y_PROFILING_ENDPOINT=http://alloy:4040
O11Y_PROFILING_APP_NAME=openmentor-api
O11Y_PROFILING_SAMPLE_TYPES=cpu,alloc_space,alloc_objects,goroutines,mutex,block
O11Y_PROFILING_UPLOAD_INTERVAL_SECONDS=15

# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# 1. Generate strong random tokens:
#    openssl rand -base64 32
#
# 2. Use DIFFERENT tokens than development
#
# 3. Rotate tokens regularly
#
# 4. The deployment script will automatically:
#    - Upload this file to /opt/openmentor-infra/.env on the VM
#    - Set proper permissions (600)
#    - Set IMAGE_TAG automatically
#
# ============================================================================

# ============================================================================
# HOW TO GET DEPLOYMENT VALUES:
# ============================================================================
#
# 1. YANDEX_REGISTRY_ID (TODO(P6.4): replaced by AWS ECR (D19) org/repo):
#    - Go to Yandex Cloud Console -> Container Registry
#    - Copy your registry ID (starts with "crp")
#
# 2. YANDEX_SA_KEY_FILE (TODO(P6.4): replaced by a AWS ECR (D19) PAT/OIDC):
#    - Create a service account in Yandex Cloud
#    - Grant it "container-registry.images.pusher" role
#    - Create a JSON key and download it
#    - Put the path to the downloaded JSON file here
#
# 3. VM_SSH_HOST:
#    - Your production VM's IP address or hostname
#    - Hetzner Cloud Console -> your project -> Servers (DECISIONS D2)
#
# 4. VM_SSH_USER:
#    - SSH username for your VM ("deploy" when provisioned via cloud-init)
#
# 5. VM_SSH_KEY_FILE (optional):
#    - Path to your SSH private key for accessing the VM
#    - Leave unset to authenticate via your SSH agent (1Password agent, ssh-agent)
#
# ============================================================================
