{
  "subject": "Confirm your email \u2014 one click to submit your OpenMentor profile",
  "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Confirm your email</title>\n</head>\n<body style=\"margin:0;padding:0;background:#EDEBE4;\">\n<div style=\"display:none;max-height:0;overflow:hidden;\">One click left \u2014 confirm your email</div>\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#EDEBE4\">\n<tr><td align=\"center\" style=\"padding:32px 12px;\">\n<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:600px;max-width:600px;background:#FFFFFF;border-radius:14px;border:1px solid #DEDBD1;\">\n<tr><td style=\"padding:28px 40px 0;\" align=\"center\"><img src=\"https://openmentor.io/brand/logo/png/icon-app/icon-app-128.png\" width=\"44\" height=\"44\" alt=\"OpenMentor\" style=\"display:block;border:0;\"></td></tr>\n<tr><td style=\"padding:22px 40px 0;\" align=\"center\"><div style=\"font:bold 26px/1.2 Arial,Helvetica,sans-serif;color:#161A20;text-transform:uppercase;letter-spacing:-0.5px;\">Confirm your email</div><div style=\"padding-top:12px;font:normal 15px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Hi {{first_name}} \u2014 thanks for creating a mentor profile on OpenMentor. One click and we'll send it to review.</div></td></tr>\n<tr><td style=\"padding:26px 40px 0;\" align=\"center\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td bgcolor=\"#132A52\" style=\"border-radius:12px;\" align=\"center\"><a href=\"{{confirm_url}}\" style=\"display:inline-block;padding:15px 34px;font:bold 15px Arial,Helvetica,sans-serif;color:#FFFFFF;text-decoration:none;\">Confirm &amp; submit for review</a></td></tr></table></td></tr>\n<tr><td style=\"padding:18px 40px 0;\" align=\"center\"><div style=\"font:normal 12px/1.7 Arial,Helvetica,sans-serif;color:#5B6270;\">The link works for 24 hours. Didn't sign up? Ignore this email and nothing happens.</div></td></tr>\n<tr><td style=\"padding:26px 40px 28px;\" align=\"center\"><div style=\"border-top:1px solid #DEDBD1;padding-top:16px;font:normal 11px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">openmentor.io \u00b7 free mentorship for the tech community</div></td></tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
  "text": "Hi {{first_name}},\n\nThanks for creating a mentor profile on OpenMentor. One click and we'll send it to review.\n\nConfirm & submit for review:\n{{confirm_url}}\n\nThe link works for 24 hours. Didn't sign up? Ignore this email and nothing happens.\n\n---\nopenmentor.io \u00b7 free mentorship for the tech community\nhttps://openmentor.io"
}
