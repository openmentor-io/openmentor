{
  "uid": "om-overview",
  "title": "OpenMentor · Overview",
  "description": "High-level health, golden signals, business KPIs and recent errors for all OpenMentor services.",
  "tags": [
    "openmentor"
  ],
  "timezone": "browser",
  "schemaVersion": 41,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "preload": false,
  "links": [
    {
      "title": "OpenMentor dashboards",
      "type": "dashboards",
      "tags": [
        "openmentor"
      ],
      "asDropdown": true,
      "includeVars": false,
      "keepTime": true,
      "icon": "external link",
      "targetBlank": false,
      "url": ""
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        },
        "definition": "label_values(http_server_request_total, service_name)",
        "query": {
          "query": "label_values(http_server_request_total, service_name)",
          "refId": "PrometheusVariableQuery"
        },
        "regex": "/openmentor-.*/",
        "multi": true,
        "includeAll": true,
        "allValue": "openmentor-.*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Service Health",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Scrape Availability",
      "description": "Percentage of Prometheus scrape targets currently up (all OpenMentor jobs).",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "avg(up) * 100",
          "refId": "A",
          "range": true,
          "instant": false,
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "mappings": [],
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "percentChangeColorMode": "standard"
      },
      "id": 2,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Request Rate",
      "description": "Total HTTP request rate across all OpenMentor services.",
