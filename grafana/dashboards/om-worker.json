        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "sum by (job, outcome) (increase(openmentor_worker_cron_runs_total[1h]))",
          "refId": "A",
          "range": true,
          "instant": false,
          "editorMode": "code",
          "legendFormat": "{{job}} / {{outcome}}"
