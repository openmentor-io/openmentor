{
  "subject": "You've received a new review",
  "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>You got a review</title>\n</head>\n<body style=\"margin:0;padding:0;background:#EDEBE4;\">\n<div style=\"display:none;max-height:0;overflow:hidden;\">{{mentee_name}} left a review of your session</div>\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#EDEBE4\">\n<tr><td align=\"center\" style=\"padding:32px 12px;\">\n<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:600px;max-width:600px;background:#FFFFFF;border-radius:14px;border:1px solid #DEDBD1;\">\n<tr><td style=\"padding:28px 40px 0;\" align=\"center\"><img src=\"https://openmentor.io/brand/logo/png/icon-app/icon-app-128.png\" width=\"44\" height=\"44\" alt=\"OpenMentor\" style=\"display:block;border:0;\"></td></tr>\n<tr><td style=\"padding:22px 40px 0;\"><div align=\"center\"><div style=\"font:bold 24px/1.2 Arial,Helvetica,sans-serif;color:#161A20;text-transform:uppercase;letter-spacing:-0.5px;\">You got a review</div></div><div style=\"padding-top:12px;font:normal 15px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Hi {{first_name}} \u2014 your mentee <b style=\"color:#161A20;\">{{mentee_name}}</b> left a review of your session:</div><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\" style=\"margin-top:16px;\"><tr><td width=\"4\" bgcolor=\"#17C3B2\" style=\"border-radius:2px;\"></td><td style=\"padding:14px 16px;background:#F7F6F2;border-radius:0 10px 10px 0;\"><div style=\"font:italic normal 13px/1.6 Arial,Helvetica,sans-serif;color:#4A5160;\">{{review_text}}</div></td></tr></table><div style=\"padding-top:16px;font:normal 15px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Thank you for helping others grow \u2014 we hope the feedback is useful.</div></td></tr>\n<tr><td style=\"padding:26px 40px 28px;\" align=\"center\"><div style=\"border-top:1px solid #DEDBD1;padding-top:16px;font:normal 11px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">openmentor.io \u00b7 free mentorship for the tech community</div></td></tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
  "text": "Hi {{first_name}},\n\nYour mentee {{mentee_name}} left a review of your session:\n\n-----\n{{review_text}}\n-----\n\nThank you for helping others grow \u2014 we hope the feedback is useful.\n\n---\nopenmentor.io \u00b7 free mentorship for the tech community\nhttps://openmentor.io"
}
