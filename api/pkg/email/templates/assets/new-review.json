{
  "subject": "You've received a new review",
  "html": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { text-align: center; margin-bottom: 30px; }\n    .header img { max-width: 200px; }\n    .content { background: #f9f9f9; padding: 30px; border-radius: 8px; }\n    .review-block { background: #ffffff; border-left: 4px solid #1188E6; padding: 16px 20px; margin: 20px 0; border-radius: 0 4px 4px 0; font-style: italic; color: #555; }\n    .footer { margin-top: 30px; font-size: 12px; color: #666; text-align: center; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <a href=\"https://openmentor.io\">\n      <img src=\"http://cdn.mcauto-images-production.sendgrid.net/9a55e6310fa94def/8a8e94ee-49fa-42cb-9c1d-f87af3f2b473/1200x320.png\" alt=\"OpenMentor\">\n    </a>\n  </div>\n  <div class=\"content\">\n    <p>Hi {{first_name}},</p>\n    <p>Your mentee <strong>{{mentee_name}}</strong> left a review of your session:</p>\n    <div class=\"review-block\">\n      {{review_text}}\n    </div>\n    <p>Thank you for helping others grow — we hope the feedback is useful!</p>\n  </div>\n  <div class=\"footer\">\n    <p>This is an automated message from OpenMentor</p>\n    <p><a href=\"https://openmentor.io\">https://openmentor.io</a></p>\n  </div>\n</body>\n</html>",
  "text": "Hi {{first_name}},\n\nYour mentee {{mentee_name}} left a review of your session:\n\n-----\n{{review_text}}\n-----\n\nThank you for helping others grow — we hope the feedback is useful!\n\n---\nThis is an automated message from OpenMentor\nhttps://openmentor.io"
}
