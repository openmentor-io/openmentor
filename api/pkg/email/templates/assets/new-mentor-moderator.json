{
  "subject": "New mentor application: {{mentor_name}}",
  "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>New mentor application</title>\n</head>\n<body style=\"margin:0;padding:0;background:#EDEBE4;\">\n<div style=\"display:none;max-height:0;overflow:hidden;\">{{mentor_name}} \u00b7 {{mentor_job}}</div>\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#EDEBE4\">\n<tr><td align=\"center\" style=\"padding:32px 12px;\">\n<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:600px;max-width:600px;background:#FFFFFF;border-radius:14px;border:1px solid #DEDBD1;\">\n<tr><td style=\"padding:26px 40px 0;\" align=\"center\"><img src=\"https://openmentor.io/brand/logo/png/icon-app/icon-app-128.png\" width=\"40\" height=\"40\" alt=\"OpenMentor\" style=\"display:block;border:0;\"></td></tr>\n<tr><td style=\"padding:18px 40px 0;\" align=\"center\"><span style=\"font:bold 11px Arial,Helvetica,sans-serif;color:#4A5160;background:#EDEBE4;padding:6px 14px;border-radius:999px;letter-spacing:1px;\">MODERATION</span><div style=\"padding-top:12px;\"><div style=\"font:bold 24px/1.2 Arial,Helvetica,sans-serif;color:#161A20;text-transform:uppercase;letter-spacing:-0.5px;\">New mentor application</div></div><div style=\"padding-top:10px;font:normal 15px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">A confirmed mentor profile is waiting for review.</div></td></tr>\n<tr><td style=\"padding:18px 40px 0;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\" style=\"margin-top:0px;background:#F7F6F2;border-radius:12px;\"><tr><td style=\"padding:16px;\"><div style=\"font:bold 15px Arial,Helvetica,sans-serif;color:#161A20;\">{{mentor_name}}</div><div style=\"padding-top:4px;font:normal 13px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">{{mentor_job}}<br>{{mentor_email}}</div></td></tr></table></td></tr>\n<tr><td style=\"padding:20px 40px 0;\" align=\"center\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td bgcolor=\"#132A52\" style=\"border-radius:12px;\" align=\"center\"><a href=\"https://openmentor.io/admin/mentors/pending\" style=\"display:inline-block;padding:14px 28px;font:bold 15px Arial,Helvetica,sans-serif;color:#FFFFFF;text-decoration:none;\">Review pending mentors</a></td></tr></table></td></tr>\n<tr><td style=\"padding:26px 40px 28px;\" align=\"center\"><div style=\"border-top:1px solid #DEDBD1;padding-top:16px;font:normal 11px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Internal notification \u00b7 openmentor.io</div></td></tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
