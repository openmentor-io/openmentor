        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "100 * (sum(rate(http_server_request_total{service_name=~\"openmentor-.*\", http_response_status_code=~\"5..\"}[$__rate_interval])) or vector(0)) / sum(rate(http_server_request_total{service_name=~\"openmentor-.*\"}[$__rate_interval]))",
