{
  "subject": "New mentorship request from {{mentee_name}}",
  "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>New request</title>\n</head>\n<body style=\"margin:0;padding:0;background:#EDEBE4;\">\n<div style=\"display:none;max-height:0;overflow:hidden;\">{{mentee_name}} sent you a mentorship request</div>\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#EDEBE4\">\n<tr><td align=\"center\" style=\"padding:32px 12px;\">\n<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:600px;max-width:600px;background:#FFFFFF;border-radius:14px;border:1px solid #DEDBD1;\">\n<tr><td bgcolor=\"#C9E6F2\" style=\"padding:28px 40px;border-radius:14px 14px 0 0;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td><img src=\"https://openmentor.io/brand/logo/png/icon-app/icon-app-128.png\" width=\"40\" height=\"40\" alt=\"OpenMentor\" style=\"display:block;border:0;\"></td><td align=\"right\"><span style=\"font:bold 11px Arial,Helvetica,sans-serif;color:#FFFFFF;background:#2F5EFF;padding:6px 14px;border-radius:999px;letter-spacing:1px;\">NEW REQUEST</span></td></tr></table><div style=\"padding-top:14px;font:bold 24px/1.2 Arial,Helvetica,sans-serif;color:#161A20;text-transform:uppercase;letter-spacing:-0.5px;\">Someone picked you</div></td></tr>\n<tr><td style=\"padding:24px 40px 0;\"><div style=\"font:normal 15px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Hi {{mentor_name}} \u2014 <b style=\"color:#161A20;\">{{mentee_name}}</b> ({{mentee_email}}) sent you a mentorship request:</div><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\" style=\"margin-top:16px;\"><tr><td width=\"4\" bgcolor=\"#2F5EFF\" style=\"border-radius:2px;\"></td><td style=\"padding:14px 16px;background:#F7F6F2;border-radius:0 10px 10px 0;\"><div style=\"font:normal 14px/1.65 Arial,Helvetica,sans-serif;color:#161A20;\">{{mentee_request}}</div></td></tr></table><div style=\"padding-top:12px;font:normal 12px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Contact: {{mentee_contact}}</div></td></tr>\n<tr><td style=\"padding:22px 40px 0;\" align=\"center\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td bgcolor=\"#132A52\" style=\"border-radius:12px;\" align=\"center\"><a href=\"https://openmentor.io/mentor/login\" style=\"display:inline-block;padding:15px 28px;font:bold 15px Arial,Helvetica,sans-serif;color:#FFFFFF;text-decoration:none;\">Open dashboard</a></td></tr></table></td></tr>\n<tr><td style=\"padding:24px 40px 28px;\" align=\"center\"><div style=\"border-top:1px solid #DEDBD1;padding-top:16px;font:normal 11px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Replying happens by email \u2014 write to {{mentee_email}} directly. Keep the request status up to date in your dashboard.</div></td></tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
  "text": "Hi {{mentor_name}},\n\n{{mentee_name}} ({{mentee_email}}) sent you a mentorship request:\n\n{{mentee_request}}\n\nContact: {{mentee_contact}}\n\nReplying happens by email \u2014 write to {{mentee_email}} directly, and keep the request status up to date in your dashboard:\nhttps://openmentor.io/mentor/login\n\n---\nopenmentor.io \u00b7 free mentorship for the tech community\nhttps://openmentor.io"
}
