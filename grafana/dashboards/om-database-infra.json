      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "100 * sum(rate(pg_stat_database_blks_hit{instance=\"db-openmentor-pg\"}[$__rate_interval])) / clamp_min(sum(rate(pg_stat_database_blks_hit{instance=\"db-openmentor-pg\"}[$__rate_interval])) + sum(rate(pg_stat_database_blks_read{instance=\"db-openmentor-pg\"}[$__rate_interval])), 1)",
