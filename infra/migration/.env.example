# ----------------------------------------------------------------------------
# yandex-to-s3-migration.js (Yandex Object Storage -> AWS S3)
# ----------------------------------------------------------------------------

# Source: Yandex Object Storage (static access key of a service account)
SOURCE_S3_ACCESS_KEY=your-yandex-access-key-id
SOURCE_S3_SECRET_KEY=your-yandex-secret-access-key
SOURCE_S3_BUCKET=your-yandex-bucket-name
# Optional overrides (defaults shown)
# SOURCE_S3_ENDPOINT=https://storage.yandexcloud.net
# SOURCE_S3_REGION=ru-central1

# Destination: AWS S3 (leave DEST_S3_ENDPOINT unset for plain AWS S3)
DEST_S3_ACCESS_KEY=your-aws-access-key-id
DEST_S3_SECRET_KEY=your-aws-secret-access-key
DEST_S3_BUCKET=mentor-images
# DEST_S3_ENDPOINT=
# DEST_S3_REGION=eu-central-1
