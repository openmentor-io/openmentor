{
  "subject": "Your OpenMentor sign-in link",
  "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Your sign-in link</title>\n</head>\n<body style=\"margin:0;padding:0;background:#EDEBE4;\">\n<div style=\"display:none;max-height:0;overflow:hidden;\">Your sign-in link (valid 15 minutes)</div>\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#EDEBE4\">\n<tr><td align=\"center\" style=\"padding:32px 12px;\">\n<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:600px;max-width:600px;background:#FFFFFF;border-radius:14px;border:1px solid #DEDBD1;\">\n<tr><td style=\"padding:28px 40px 0;\" align=\"center\"><img src=\"https://openmentor.io/brand/logo/png/icon-app/icon-app-128.png\" width=\"44\" height=\"44\" alt=\"OpenMentor\" style=\"display:block;border:0;\"></td></tr>\n<tr><td style=\"padding:20px 40px 0;\" align=\"center\"><div style=\"font:bold 24px/1.2 Arial,Helvetica,sans-serif;color:#161A20;text-transform:uppercase;letter-spacing:-0.5px;\">Your sign-in link</div><div style=\"padding-top:10px;font:normal 15px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Hi {{mentor_name}} \u2014 click below to open your mentor dashboard. No password needed.</div></td></tr>\n<tr><td style=\"padding:24px 40px 0;\" align=\"center\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td bgcolor=\"#132A52\" style=\"border-radius:12px;\" align=\"center\"><a href=\"{{login_url}}\" style=\"display:inline-block;padding:16px 40px;font:bold 15px Arial,Helvetica,sans-serif;color:#FFFFFF;text-decoration:none;\">Sign in to OpenMentor</a></td></tr></table></td></tr>\n<tr><td style=\"padding:18px 40px 0;\" align=\"center\"><div style=\"font:normal 12px/1.7 Arial,Helvetica,sans-serif;color:#5B6270;\">Valid for <b style=\"color:#161A20;\">15 minutes</b> and works once.<br>Didn't request this? Ignore it \u2014 no one can sign in without this email.</div></td></tr>\n<tr><td style=\"padding:24px 40px 28px;\" align=\"center\"><div style=\"border-top:1px solid #DEDBD1;padding-top:16px;font:normal 11px/1.6 Arial,Helvetica,sans-serif;color:#5B6270;\">Sent because someone requested a sign-in link for this address at openmentor.io</div></td></tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
  "text": "Hi {{mentor_name}},\n\nClick the link below to open your mentor dashboard. No password needed.\n\nSign in to OpenMentor:\n{{login_url}}\n\nThe link is valid for 15 minutes and works once.\nDidn't request this? Ignore it \u2014 no one can sign in without this email.\n\n---\nopenmentor.io \u00b7 free mentorship for the tech community\nhttps://openmentor.io"
}
