        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "sum(rate(http_server_request_total{service_name=~\"openmentor-.*\"}[$__rate_interval]))",
          "refId": "A",
          "range": true,
          "instant": false,
