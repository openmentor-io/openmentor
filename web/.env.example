# Go API Configuration
NEXT_PUBLIC_GO_API_URL=http://localhost:8081
GO_API_INTERNAL_TOKEN=your_internal_api_token_here

# ReCAPTCHA (client-side only, Go API handles verification)
NEXT_PUBLIC_RECAPTCHA_V2_SITE_KEY=

# S3-compatible object storage (profile images; AWS S3 per DECISIONS)
# AWS path-style example: NEXT_PUBLIC_S3_STORAGE_ENDPOINT=s3.eu-central-1.amazonaws.com
NEXT_PUBLIC_S3_STORAGE_ENDPOINT=
NEXT_PUBLIC_S3_STORAGE_BUCKET=mentor-images

# Optional CDN in front of the storage bucket. When set, image URLs are built
# as https://<CDN_ENDPOINT>/... instead of https://<S3_ENDPOINT>/<bucket>/...
# NEXT_PUBLIC_CDN_ENDPOINT=

# Canonical domain used for SEO/meta URLs and the sitemap (production only)
# DOMAIN=openmentor.io

# Metrics Authentication (for /api/metrics endpoint security)
METRICS_AUTH_TOKEN=your_metrics_auth_token_here

# Logging Configuration
LOG_LEVEL=info
# LOG_DIR: Directory for log files (default: ./logs in dev, /app/logs in production)
# LOG_DIR=/app/logs

# Observability Configuration - Grafana Faro (client-side)
# NEXT_PUBLIC_FARO_COLLECTOR_URL: Grafana Cloud Faro collector URL.
# The browser SDK posts to /faro-collect, which Next.js rewrites to this URL
# (see next.config.js). Leave empty/unset to disable client-side telemetry.
# NEXT_PUBLIC_FARO_COLLECTOR_URL=https://faro-collector-prod-eu-west-3.grafana.net/collect/your-app-key

# Service Identity (client-side Faro resource attributes)
NEXT_PUBLIC_FARO_APP_NAME=openmentor-frontend
NEXT_PUBLIC_O11Y_SERVICE_NAMESPACE=openmentor-io
NEXT_PUBLIC_O11Y_FE_SERVICE_VERSION=1.0.0

# Faro Sampling Rate (0.0 to 1.0, where 1.0 = 100%)
NEXT_PUBLIC_FARO_SAMPLE_RATE=1.0

# Server-side OpenTelemetry tracing (Node.js runtime; sensible defaults built in)
# O11Y_EXPORTER_ENDPOINT: OTLP HTTP endpoint (default: http://alloy:4318)
# O11Y_FE_SERVICE_NAME / O11Y_SERVICE_NAMESPACE / O11Y_FE_SERVICE_VERSION:
#   server-side service identity (defaults: openmentor-frontend / openmentor-io / 1.0.0)
# APP_ENV: server-side environment label (falls back to NODE_ENV)
# SERVICE_INSTANCE_ID: stable instance id for traces (default: random UUID)
# O11Y_EXPORTER_ENDPOINT=http://alloy:4318
# O11Y_FE_SERVICE_NAME=openmentor-frontend
# O11Y_SERVICE_NAMESPACE=openmentor-io
# O11Y_FE_SERVICE_VERSION=1.0.0
# APP_ENV=production
# SERVICE_INSTANCE_ID=

# Application Environment (production, staging, development)
NEXT_PUBLIC_APP_ENV=production

# Analytics Provider
# Options: none | mixpanel | posthog | dual
# PostHog browser SDK is expected to be loaded via GTM when using posthog/dual.
# Reverse-proxy example (configured in GTM, not in app env):
# posthog.init('<project-api-key>', { api_host: 'https://a.openmentor.io', ui_host: 'https://eu.posthog.com' })
NEXT_PUBLIC_ANALYTICS_PROVIDER=mixpanel
NEXT_PUBLIC_ANALYTICS_EVENT_VERSION=v1

# PostHog Error Tracking
# NEXT_PUBLIC_POSTHOG_KEY: PostHog project API key (phc_...)
# NEXT_PUBLIC_POSTHOG_HOST: PostHog ingest endpoint (https://eu.i.posthog.com)
# POSTHOG_PERSONAL_API_KEY: Personal API key for source map uploads (phx_...)
# POSTHOG_PROJECT_ID: PostHog project ID for source map uploads
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=
